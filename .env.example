# Shared — all services
Jwt__Secret=your-super-secret-key-at-least-32-chars
Jwt__Issuer=TasksApp.AuthService
Jwt__Audience=TasksApp
Jwt__ExpiryHours=1

# AuthService
ConnectionStrings__AuthDb=Server=localhost;Port=3306;Database=auth_db;Uid=root;Pwd=your-db-password;

# TaskService
ConnectionStrings__TasksDb=Server=localhost;Port=3306;Database=tasks_db;Uid=taskuser;Pwd=your-db-password;
AuthService__GrpcAddress=http://localhost:5101
